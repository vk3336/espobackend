# ============================================================
# ESPO CRM CONFIGURATION
# ============================================================

# Base URL of your EspoCRM instance
ESPO_BASE_URL=https://your-espocrm-domain.com

# API key from EspoCRM: Admin > API Keys
ESPO_API_KEY=your_espocrm_api_key_here


# ============================================================
# ENTITIES CONFIGURATION
# ============================================================

# Comma-separated list of EspoCRM entity types to expose via API
ESPO_ENTITIES=CProduct,CCollection,CCompanyInformation,CSiteSettings,CBlog,CAuthor,Lead,CTopicPage,CRedirect,CCustomerAccount,CWishlist,CCareer,CLocation,CProductLocation,CEmployeeMaster


# Fields to fetch from CCollection when populating collection relation
ESPO_COLLECTION_SELECT_FIELDS=id,name,slug,collectionImage1CloudUrl,altTextCollectionImage1,collectionvideoURL,collectionaltTextVideo

# Fields to fetch from CProduct when populating product relation
ESPO_PRODUCT_SELECT_FIELDS=id,name,slug,category,color,fullProductDescription,structure,content,design,motif,uM,gsm,ozs,cm,inch,salesMOQ,videoURL,altTextImage1,altTextImage2,altTextImage3,altTextVideo,supplyModel,finish,keywords,image1CloudUrl,image2CloudUrl,image3CloudUrl,suitability,collectionId,collectionName,isStarred,assignedUserId

# Fields to fetch from CLocation when populating location relation
ESPO_LOCATION_SELECT_FIELDS=id,name,locationslug,description,locationTagline,pincode,longitude,latitude,image1CloudUrl,altTextImage1


# ============================================================
# FALLBACK IMAGES (Cloudinary URLs shown when no image exists)
# ============================================================

# Cloudinary URL for product fallback image
productfallbackimage1=https://res.cloudinary.com/your-cloud-name/image/upload/v0000000000/your-product-fallback-image.jpg

# Cloudinary URL for blog fallback image
blogfallbackimage1=https://res.cloudinary.com/your-cloud-name/image/upload/v0000000000/your-blog-fallback-image.jpg


# ============================================================
# FRONTEND URLS
# ============================================================

# Primary frontend base URL (used for CORS, revalidation, QR codes, etc.)
FRONTEND_URL=https://www.your-frontend-domain.com

# Secondary/staging frontend revalidation endpoint (Next.js ISR)
FRONTEND_B_REVALIDATE_URL=https://your-staging-frontend.vercel.app/api/revalidate

# Product catalog URL used for QR code generation (usually FRONTEND_URL/fabric)
AGE_FRONTEND_URL=${FRONTEND_URL}/fabric

# Backend company information API endpoint
BACKEND_COMPANY_INFORMATION=https://your-backend-domain.vercel.app/api/companyinformation


# ============================================================
# CORS & RATE LIMITING
# ============================================================

# Comma-separated list of allowed origins (no spaces)
CORS_ORIGIN=localhost,https://your-staging-frontend.vercel.app,${FRONTEND_URL}

# Maximum number of requests per window per IP
RATE_LIMIT_MAX_REQUESTS=100


# ============================================================
# CHAT ASSISTANT (OpenAI)
# ============================================================

# OpenAI API key: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-openai-api-key-here

# Entities the public chat assistant can query
CHAT_ENTITIES=CProduct,CCollection,CCompanyInformation

# Entities the admin chat assistant can query
ADMIN_CHAT_ENTITIES=CProduct,CCollection,CCompanyInformation

# Extra instructions to control reply style/behavior (plain text, use \n for new lines)
CHAT_EXTRA_INSTRUCTIONS=Reply with emojis. \n Use short bullets. Keep it friendly. Ask only ONE question at the end.\nNever mention internal IDs.\nIf unsure, say so.

# Default phone country code for customer registration
DEFAULT_PHONE_COUNTRY_CODE=+91


# ============================================================
# INDEXNOW (Search Engine Ping)
# ============================================================

# Enable or disable the IndexNow scheduler (true/false)
INDEXNOW_SCHEDULER_ENABLED=true

# Your IndexNow ownership key (8-128 chars: a-z A-Z 0-9 and -)
# Generate one at: https://www.indexnow.org/
INDEXNOW_KEY=your-indexnow-key-here


# ============================================================
# CACHE CONFIGURATION
# ============================================================

# Entities that should NEVER be cached (always fetched fresh), comma-separated
NO_CACHE_ENTITIES=CCustomerAccount,CWishlist

# TTL in seconds for NO_CACHE entities (set to 0 for always-fresh)
NO_CACHE_SHORT_TTL_SECONDS=0

# How often to check for changed records (seconds; default: 300 = 5 minutes)
ESPO_DELTA_REFRESH_SECONDS=300

# How often to do a full refresh to catch deleted records (seconds; default: 86400 = 24 hours)
ESPO_FULL_REFRESH_SECONDS=86400

# How long to keep cache alive (seconds; default: 172800 = 48 hours)
ESPO_CACHE_TTL_SECONDS=172800

# Run startup jobs like cache warmer and schedulers (set false for serverless environments)
RUN_STARTUP_JOBS=false


# ============================================================
# REVALIDATION SECRET (Next.js ISR)
# ============================================================

# Secret token used to authenticate revalidation requests from this backend to the frontend
# Must match the REVALIDATE_SECRET set in your Next.js frontend environment
REVALIDATE_SECRET=your-strong-random-secret-here


# ============================================================
# EMAIL / OTP (Gmail)
# ============================================================

# Gmail address used to send OTP emails
GMAIL_USER=your-gmail-address@gmail.com

# Gmail App Password (NOT your regular password)
# Generate at: https://myaccount.google.com/apppasswords
GMAIL_APP_PASSWORD=your-gmail-app-password-here

# Secret used to sign/verify OTP tokens (use a long random string)
OTP_SECRET=your-long-random-otp-secret-here
